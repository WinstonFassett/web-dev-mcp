{
  "name": "web-dev-mcp",
  "version": "0.1.0",
  "description": "Monorepo for web development MCP tools",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=vite-live-dev-mcp && npm run build --workspace=web-dev-mcp-gateway",
    "dev": "npm run dev --workspaces",
    "test": "npm run test --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "cleanup": "./scripts/cleanup-dev-servers.sh"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "playwright": "^1.58.2",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "mcp",
    "web",
    "devtools",
    "ai",
    "vite",
    "nextjs"
  ],
  "license": "MIT"
}
