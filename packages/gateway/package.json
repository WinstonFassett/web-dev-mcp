{
  "name": "web-dev-mcp-gateway",
  "version": "0.1.0",
  "description": "Universal web development MCP gateway — proxy any dev server with live browser observability for AI agents",
  "type": "module",
  "main": "dist/gateway.js",
  "types": "dist/gateway.d.ts",
  "bin": {
    "web-dev-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/gateway.d.ts",
      "import": "./dist/gateway.js",
      "default": "./dist/gateway.js"
    },
    "./vite": {
      "types": "./dist/adapters/vite.d.ts",
      "import": "./dist/adapters/vite.js",
      "default": "./dist/adapters/vite.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs/index.d.ts",
      "import": "./dist/nextjs/index.js",
      "default": "./dist/nextjs/index.js"
    },
    "./nextjs/instrument": {
      "types": "./dist/nextjs/instrument.d.ts",
      "import": "./dist/nextjs/instrument.js",
      "default": "./dist/nextjs/instrument.js"
    },
    "./agent": {
      "types": "./dist/agent-client.d.ts",
      "import": "./dist/agent-client.js",
      "default": "./dist/agent-client.js"
    },
    "./storybook": {
      "types": "./dist/storybook/preset.d.ts",
      "import": "./dist/storybook/preset.js",
      "require": "./dist/storybook/preset.cjs",
      "default": "./dist/storybook/preset.js"
    },
    "./storybook/preset": {
      "types": "./dist/storybook/preset.d.ts",
      "import": "./dist/storybook/preset.js",
      "require": "./dist/storybook/preset.cjs",
      "default": "./dist/storybook/preset.cjs"
    },
    "./storybook/preview": {
      "types": "./dist/storybook/preview.d.ts",
      "import": "./dist/storybook/preview.js",
      "require": "./dist/storybook/preview.cjs",
      "default": "./dist/storybook/preview.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node build-client.mjs && cp src/storybook/*.cjs dist/storybook/ 2>/dev/null || true",
    "build:client": "node build-client.mjs",
    "dev": "tsc --watch",
    "test": "node dist/cli.js"
  },
  "keywords": [
    "mcp",
    "web",
    "devtools",
    "proxy",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WinstonFassett/web-dev-mcp.git",
    "directory": "packages/gateway"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "capnweb": "^0.6.1",
    "element-source": "^0.0.5",
    "modern-screenshot": "^4.6.8",
    "ws": "^8.20.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "storybook": ">=8.0.0",
    "vite": ">=6.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "storybook": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
