{
  "name": "vite-live-dev-mcp",
  "version": "0.1.0",
  "description": "Vite plugin giving AI coding agents live observability into running React apps via MCP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vite-live-dev-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "client"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "keywords": [
    "vite",
    "mcp",
    "ai",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WinstonFassett/web-dev-mcp.git",
    "directory": "packages/vite-plugin"
  },
  "license": "MIT",
  "peerDependencies": {
    "bippy": ">=0.5.0",
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "bippy": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "capnweb": "^0.6.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "playwright": "^1.58.2",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
